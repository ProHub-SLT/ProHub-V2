@model ProHub.Models.Company
@{
    ViewData["Title"] = "Edit Company";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        body::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%;
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }

    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

    .form-body {
        padding: 2.5rem;
    }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-control-modern:focus {
            border-color: #28A745;
            background-color: #fff;
            outline: none;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #718096;
            z-index: 2;
        }

    .btn-modern-primary {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
    }

        .btn-modern-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
            color: white;
        }

    .btn-modern-secondary {
        background: white;
        color: #495057;
        border: 2px solid #dee2e6;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
    }

        .btn-modern-secondary:hover {
            background: #f8f9fa;
            transform: translateY(-1px);
            border-color: #ced4da;
            color: #212529;
        }

    .field-description {
        background: #f0f9ff;
        border-left: 3px solid #007BFF;
        padding: 0.75rem 1rem;
        margin-bottom: 2rem;
        border-radius: 4px;
    }

    /* Success Popup Styles */
    .success-popup {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
    }

        .success-popup.hidden {
            display: none;
        }

    .success-popup-content {
        background: white;
        padding: 2.5rem;
        border-radius: 15px;
        text-align: center;
        max-width: 400px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

        .success-popup-content i {
            font-size: 4rem;
            color: #28a745;
            display: block;
            margin-bottom: 1rem;
        }
</style>

<div id="successPopup" class="success-popup hidden">
    <div class="success-popup-content">
        <i class="bi bi-check-circle-fill"></i>
        <h3>Success!</h3>
        <p>The company details have been updated successfully.</p>
        <button id="popupCloseBtn" class="btn-modern-primary w-100 justify-content-center">Continue</button>
    </div>
</div>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2 class="m-0"><i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]</h2>
            <p class="m-0 mt-2 opacity-75">Update the details for <strong>@Model.CompanyName</strong></p>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-body">
                <div class="field-description">
                    <i class="bi bi-info-circle me-2"></i>
                    Fields marked with <span class="text-danger">*</span> are required
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger shadow-sm">
                        <strong><i class="bi bi-exclamation-triangle me-2"></i>Please fix the following errors:</strong>
                        <div asp-validation-summary="All" class="mt-2 mb-0"></div>
                    </div>
                }

                <div class="mb-4">
                    <label asp-for="CompanyName" class="fw-bold mb-2">Company Name <span class="text-danger">*</span></label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-building"></i>
                        <input asp-for="CompanyName" class="form-control-modern" placeholder="Enter company name" required />
                    </div>
                    <span asp-validation-for="CompanyName" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-save me-2"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Synchronized validation logic
        document.querySelector('form').addEventListener('submit', function (e) {
            const requiredFields = this.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value || field.value.trim() === "") {
                    isValid = false;
                    field.style.borderColor = '#dc3545';
                    field.style.boxShadow = '0 0 0 3px rgba(220, 53, 69, 0.1)';
                } else {
                    field.style.borderColor = '#e2e8f0';
                    field.style.boxShadow = 'none';
                }
            });

            if (!isValid) {
                e.preventDefault();
                // You could replace this alert with a more modern toast notification later
                alert('Please fill in all required fields marked with *');
            }
        });

        // Popup logic triggered by TempData
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                window.addEventListener('DOMContentLoaded', () => {
                    document.getElementById('successPopup').classList.remove('hidden');
                });
                </text>
        }

        document.getElementById('popupCloseBtn')?.addEventListener('click', () => {
            window.location.href = '@Url.Action("Index")';
        });
    </script>
}