@model ProHub.Models.CustomerContact
@{
    ViewData["Title"] = "Edit Contact";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        /* Blur overlay */
        body::before {
            content: "";
            position: absolute; /* changed from fixed */
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%; /* ensures it stretches with content */
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }

    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .form-header p {
            margin: 0.5rem 0 0 0;
            opacity: 0.9;
            font-size: 0.95rem;
        }

    .form-body {
        padding: 2.5rem;
    }

    .form-group-modern {
        margin-bottom: 1.75rem;
    }

    .form-label-modern {
        display: block;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

        .form-label-modern .required {
            color: #dc3545;
            margin-left: 0.25rem;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #718096;
            font-size: 1rem;
        }

        .input-icon-wrapper .form-control-modern {
            padding-left: 2.75rem;
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .btn-modern-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        cursor: pointer;
    }

        .btn-modern-primary:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
        }

    .btn-modern-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #495057;
        font-weight: 500;
        font-size: 0.95rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-modern-secondary:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            color: #212529;
            transform: translateY(-1px);
        }

    .field-description {
        background: #f0f9ff;
        border-left: 3px solid #007BFF;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        color: #2d3748;
    }
</style>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2><i class="bi bi-person-badge me-2"></i>@ViewData["Title"]</h2>
            <p>Update the contact information below</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="ID" />
            <div class="form-body">
                <div class="field-description">
                    <i class="bi bi-info-circle me-2"></i>
                    Update the fields below to modify the contact details
                </div>



                <!-- Company and Platform Row -->
                <div class="form-row">
                    <!-- Company -->
                    <div class="form-group-modern">
                        <label asp-for="Contact_Company" class="form-label-modern">
                            <i class="bi bi-building-check me-1"></i> Company <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-building-fill"></i>
                            <select asp-for="Contact_Company" class="form-control-modern"
                                    asp-items="@(new SelectList(ViewBag.Companies, "Id", "CompanyName", Model.Contact_Company))">
                            </select>
                        </div>
                        <span asp-validation-for="Contact_Company" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Platform -->
                    <div class="form-group-modern">
                        <label asp-for="Platform_ID" class="form-label-modern">
                            <i class="bi bi-app-indicator me-1"></i> Platform <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-pc-display-horizontal"></i>
                            <select asp-for="Platform_ID" class="form-control-modern"
                                    asp-items="@(new SelectList(ViewBag.Platforms, "Id", "PlatformName", Model.Platform_ID))">
                            </select>
                        </div>
                        <span asp-validation-for="Platform_ID" class="text-danger small mt-1 d-block"></span>
                    </div>

                </div>


                <!-- Title and Name Row -->
                <div class="form-row">
                    <div class="form-group-modern">
                        <label asp-for="Customer_Title" class="form-label-modern"><i class="bi bi-award me-1"></i> Title <span class="required">*</span></label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-award-fill"></i>
                            <select asp-for="Customer_Title" class="form-control-modern" asp-items="@(new SelectList(ViewBag.Titles))">
                                <option value="">Select Title</option>
                            </select>
                        </div>
                        <span asp-validation-for="Customer_Title" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Contact_Name" class="form-label-modern"><i class="bi bi-person me-1"></i> Contact Name <span class="required">*</span></label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-person-fill"></i>
                            <input asp-for="Contact_Name" class="form-control-modern" placeholder="Enter contact name" />
                        </div>
                        <span asp-validation-for="Contact_Name" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <!-- Phone Numbers Row -->
                <div class="form-row">
                    <div class="form-group-modern">
                        <label asp-for="Contact_Phone1" class="form-label-modern"><i class="bi bi-telephone me-1"></i> Phone 1 <span class="required">*</span></label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-telephone-fill"></i>
                            <input asp-for="Contact_Phone1" class="form-control-modern" placeholder="Enter primary phone" />
                        </div>
                        <span asp-validation-for="Contact_Phone1" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Contact_Phone2" class="form-label-modern"><i class="bi bi-phone me-1"></i> Phone 2</label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-phone-fill"></i>
                            <input asp-for="Contact_Phone2" class="form-control-modern" placeholder="Enter secondary phone" />
                        </div>
                        <span asp-validation-for="Contact_Phone2" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>


                <div class="form-row">
                    <!-- Email -->
                    <div class="form-group-modern">
                        <label asp-for="Contact_Email" class="form-label-modern"><i class="bi bi-envelope me-1"></i> Email <span class="required">*</span></label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-envelope-fill"></i>
                            <input asp-for="Contact_Email" type="email" class="form-control-modern" placeholder="Enter email address" />
                        </div>
                        <span asp-validation-for="Contact_Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Designation -->
                    <div class="form-group-modern">
                        <label asp-for="Contact_Designation" class="form-label-modern"><i class="bi bi-briefcase me-1"></i> Designation</label>
                        <div class="input-icon-wrapper">
                            <i class="bi bi-briefcase-fill"></i>
                            <input asp-for="Contact_Designation" class="form-control-modern" placeholder="Enter designation" />
                        </div>
                        <span asp-validation-for="Contact_Designation" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
              

               
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-check-circle"></i> Update Contact
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
