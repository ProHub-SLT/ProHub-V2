@model ProHub.Models.Document
@{
    ViewData["Title"] = "Add - New External Document";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        /* Blur overlay */
        body::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%;
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }

    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

    .form-body {
        padding: 2.5rem;
    }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .btn-modern-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        cursor: pointer;
    }

        .btn-modern-primary:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
        }

    .btn-modern-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #495057;
        font-weight: 500;
        font-size: 0.95rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-modern-secondary:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            color: #212529;
            transform: translateY(-1px);
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .form-select-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-select-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .col-form-label {
        font-weight: 500;
        color: #495057;
        font-size: 0.9rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .alert {
        border-radius: 0.375rem;
    }

    /* Disabled field styling */
    .form-control-modern:disabled, .form-select-modern:disabled {
        background-color: #e9ecef;
        color: #6c757d;
        cursor: not-allowed;
        opacity: 0.8;
    }

    /* Disabled field label styling */
    .col-form-label.disabled {
        color: #6c757d;
    }
</style>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2 class="bi bi-file-earmark-plus me-2">@ViewData["Title"]</h2>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="form-body">
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label disabled">Platform</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control-modern" value="@(ViewBag.ExternalPlatformName ?? "External")" readonly disabled />
                        <input type="hidden" asp-for="Platform_ID" value="@(ViewBag.ExternalPlatformId ?? 2)" />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Solution_ID" class="col-sm-4 col-form-label">Solution</label>
                    <div class="col-sm-8">
                        <select asp-for="Solution_ID" class="form-select-modern" asp-items="@(ViewBag.ExternalPlatforms != null ? new SelectList(ViewBag.ExternalPlatforms, "Id", "PlatformName") : new SelectList(new List<ExternalPlatform>()))" required>
                            <option value="">Select Solution</option>
                        </select>
                        <span asp-validation-for="Solution_ID" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Doc_Name" class="col-sm-4 col-form-label">Document Name</label>
                    <div class="col-sm-8">
                        <input asp-for="Doc_Name" class="form-control-modern" required />
                        <span asp-validation-for="Doc_Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label disabled">Uploaded By</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control-modern" value="@(ViewBag.CreatedByName ?? "Unknown User")" readonly disabled />
                        <input type="hidden" name="Created_By" value="@(ViewBag.AuthenticatedEmployeeId ?? 5)" />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Doc_Classification" class="col-sm-4 col-form-label">Document Classification</label>
                    <div class="col-sm-8">
                        <input asp-for="Doc_Classification" class="form-control-modern" />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Tags" class="col-sm-4 col-form-label">Tags</label>
                    <div class="col-sm-8">
                        <input asp-for="Tags" class="form-control-modern" placeholder="e.g. UAT, Architecture" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Confidentiality</label>
                    <div class="col-sm-8">
                        <select class="form-select-modern">
                            <option>Low</option>
                            <option>Medium</option>
                            <option>High</option>
                        </select>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">ImagePath</label>
                    <div class="col-sm-8">
                        <input type="file" name="ImagePath" class="form-control-modern" accept=".pdf,.docx,.xlsx,.png,.jpg" required />
                    </div>
                </div>
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">Back to List</a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-check-circle"></i> Create
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}