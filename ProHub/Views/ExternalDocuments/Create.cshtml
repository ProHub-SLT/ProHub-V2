@model ProHub.Models.Document
@{
    ViewData["Title"] = "Create - External Document";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        /* Blur overlay */
        body::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%;
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }

    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

    .form-body {
        padding: 2.5rem;
    }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .btn-modern-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        cursor: pointer;
    }

        .btn-modern-primary:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
        }

    .btn-modern-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #495057;
        font-weight: 500;
        font-size: 0.95rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-modern-secondary:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            color: #212529;
            transform: translateY(-1px);
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .form-select-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-select-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .col-form-label {
        font-weight: 500;
        color: #495057;
        font-size: 0.9rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .alert {
        border-radius: 0.375rem;
    }

    /* Disabled field styling */
    .form-control-modern:disabled, .form-select-modern:disabled {
        background-color: #e9ecef;
        color: #6c757d;
        cursor: not-allowed;
        opacity: 0.8;
    }

    /* Disabled field label styling */
    .col-form-label.disabled {
        color: #6c757d;
        font-style: italic;
    }

    /* Custom Scrollable Dropdown */
    .dropdown-menu-scrollable {
        max-height: 250px;
        overflow-y: auto;
    }
    .search-item {
        position: sticky;
        top: 0;
        background: white;
        z-index: 1000;
        padding: 0.5rem;
        border-bottom: 1px solid #dee2e6;
    }
</style>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2 class="bi bi-file-earmark-plus me-2">@ViewData["Title"]</h2>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-3 mx-4">@TempData["Error"]</div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="form-body">
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label disabled">Platform</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control-modern" value="@(ViewBag.ExternalPlatformName ?? "External")" readonly disabled />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Solution_ID" class="col-sm-4 col-form-label">Solution</label>
                    <div class="col-sm-8 position-relative">
                        <!-- Hidden input to store selected value -->
                        <input type="hidden" asp-for="Solution_ID" id="Solution_ID" required />

                        <!-- Custom Dropdown Trigger -->
                        <div class="dropdown">
                            <button class="form-select-modern text-start d-flex justify-content-between align-items-center" type="button"
                                id="solutionDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="solutionDropdownText">Select Solution</span>
                                <i class="bi bi-chevron-down small text-muted"></i>
                            </button>

                            <!-- Dropdown Menu -->
                            <ul class="dropdown-menu w-100 shadow border-0 dropdown-menu-scrollable" aria-labelledby="solutionDropdown">
                                <li class="search-item">
                                    <input type="text" class="form-control-modern form-control-sm" id="solutionSearch" 
                                           placeholder="Search solutions..." onclick="event.stopPropagation()">
                                </li>
                                @if (ViewBag.ExternalPlatforms != null)
                                {
                                    foreach (var item in ViewBag.ExternalPlatforms)
                                    {
                                        <li>
                                            <button class="dropdown-item solution-option" type="button" 
                                                    data-id="@item.Id" data-name="@item.PlatformName">
                                                @item.PlatformName
                                            </button>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li><span class="dropdown-item text-muted">No solutions available</span></li>
                                }
                            </ul>
                        </div>
                        <span asp-validation-for="Solution_ID" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Doc_Name" class="col-sm-4 col-form-label">Document Name</label>
                    <div class="col-sm-8">
                        <input asp-for="Doc_Name" class="form-control-modern" required placeholder="Enter document name" />
                        <span asp-validation-for="Doc_Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label disabled">Uploaded By</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control-modern" value="@(ViewBag.CreatedByName ?? "Unknown User")" readonly disabled />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Doc_Classification" class="col-sm-4 col-form-label">Document Classification</label>
                    <div class="col-sm-8">
                        <input asp-for="Doc_Classification" class="form-control-modern" placeholder="e.g. Secret, Public" />
                    </div>
                </div>

                <div class="form-group row">
                    <label asp-for="Tags" class="col-sm-4 col-form-label">Tags</label>
                    <div class="col-sm-8">
                        <input asp-for="Tags" class="form-control-modern" placeholder="e.g. UAT, Architecture, Proposal" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Confidentiality</label>
                    <div class="col-sm-8">
                        <select class="form-select-modern" asp-for="Confidential">
                            <option value="false">Low</option>
                            <option value="true">High</option>
                        </select>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Upload Document</label>
                    <div class="col-sm-8">
                        <input type="file" name="ImagePath" class="form-control-modern" accept=".pdf,.docx,.xlsx,.png,.jpg" required />
                        <small class="text-muted">Allowed files: .pdf, .docx, .xlsx, .png, .jpg</small>
                    </div>
                </div>
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">Back to List</a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-cloud-arrow-up"></i> Create Document
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dropdownText = document.getElementById('solutionDropdownText');
            const hiddenInput = document.getElementById('Solution_ID');
            const searchInput = document.getElementById('solutionSearch');

            // Handle Selection
            document.querySelectorAll('.solution-option').forEach(item => {
                item.addEventListener('click', function () {
                    const id = this.getAttribute('data-id');
                    const name = this.getAttribute('data-name');
                    
                    hiddenInput.value = id;
                    dropdownText.textContent = name;
                    dropdownText.classList.remove('text-muted'); // Ensure text doesn't look like placeholder
                });
            });

            // Handle Search
            if (searchInput) {
                searchInput.addEventListener('keyup', function () {
                    const value = this.value.toLowerCase();
                    const items = this.closest('.dropdown-menu').querySelectorAll('.solution-option');

                    items.forEach(btn => {
                        const text = btn.textContent.toLowerCase();
                        const li = btn.closest('li');
                        if (text.includes(value)) {
                            li.style.display = '';
                        } else {
                            li.style.display = 'none';
                        }
                    });
                });

            // Prevent close on click
                searchInput.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            }

            // Manual Validation for Hidden Input on Submit
            const form = document.querySelector('form');
            form.addEventListener('submit', function (e) {
                const validationSpan = document.querySelector('span[data-valmsg-for="Solution_ID"]');
                
                if (!hiddenInput.value) {
                    e.preventDefault(); // Stop submission
                    
                    if (validationSpan) {
                        validationSpan.textContent = "Solution is required";
                        validationSpan.classList.remove("field-validation-valid");
                        validationSpan.classList.add("field-validation-error");
                    }
                    
                    // Highlight the dropdown button
                    dropdownText.parentElement.style.borderColor = '#dc3545';
                    dropdownText.parentElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                    // Reset if valid
                    if (validationSpan) {
                        validationSpan.textContent = "";
                        validationSpan.classList.add("field-validation-valid");
                        validationSpan.classList.remove("field-validation-error");
                    }
                    dropdownText.parentElement.style.borderColor = '#e2e8f0';
                }
            });
        });
    </script>
}
