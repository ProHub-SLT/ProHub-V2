@model ProHub.Models.ExternalPlatform
@{
    ViewData["Title"] = "Retired External Solution Details";
}
<style>
    .details-wrapper {
        margin: 20px;
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        font-size: 13px;
    }

        .details-wrapper h2 {
            margin-bottom: 18px;
            font-size: 20px;
            font-weight: 600;
        }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(240px,1fr));
        gap: 12px;
    }

    .card {
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 10px;
        background: #fafafa;
    }

        .card span.label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: #374151;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: 4px;
        }

    .back-link {
        margin-top: 18px;
        display: inline-block;
        padding: 6px 14px;
        background: #0d6efd;
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 12px;
    }

        .back-link:hover {
            background: #0b5ed7;
        }
</style>
<div class="details-wrapper">
    <h2>Retired External Solution - @Model.PlatformName</h2>
    <div class="grid">
        <div class="card"><span class="label">Platform Type</span>@Model.PlatformType</div>
        <div class="card"><span class="label">Status</span>@Model.Status</div>
        <div class="card"><span class="label">Sales AM</span>@Model.SalesAM</div>
        <div class="card"><span class="label">Company</span>@Model.Company?.CompanyName</div>
        <div class="card"><span class="label">Developed By</span>@Model.DevelopedBy?.EmpName</div>
        <div class="card"><span class="label">Start Date</span>@Model.StartDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">Target Date</span>@Model.TargetDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">UAT Date</span>@Model.UATDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">VA Date</span>@Model.VADate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">Launched Date</span>@Model.LaunchedDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">Platform OTC</span>@Model.PlatformOTC?.ToString("N2")</div>
        <div class="card"><span class="label">Platform MRC</span>@Model.PlatformMRC?.ToString("N2")</div>
        <div class="card"><span class="label">Contract Period</span>@Model.ContractPeriod</div>
        <div class="card"><span class="label">Proposal Uploaded</span>@Model.ProposalUploaded</div>
        <div class="card"><span class="label">SLA</span>@Model.SLA</div>
        <div class="card"><span class="label">Software Value</span>@Model.SoftwareValue?.ToString("N2")</div>
        <div class="card"><span class="label">SSL Certificate Exp</span>@Model.SSLCertificateExpDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">DPO Handover Date</span>@Model.DPOHandoverDate?.ToString("yyyy-MM-dd")</div>
        <div class="card"><span class="label">DPO Handover Comment</span>@Model.DPOHandoverComment</div>
        <div class="card"><span class="label">BitBucket</span>@Model.BitBucket</div>
        <div class="card"><span class="label">BIT Bucket Repo</span>@Model.BITBucketRepo</div>
        <div class="card"><span class="label">Integrated Apps</span>@Model.IntegratedApps</div>
    </div>
    <a class="back-link" asp-action="Index">Back to Retired List</a>
</div>
