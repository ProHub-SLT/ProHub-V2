@model ProHub.Models.FieldsOfSpecialization
@{
    ViewData["Title"] = "Edit Field of Specialization";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        /* Blur overlay */
        body::before {
            content: "";
            position: absolute; /* changed from fixed */
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%; /* ensures it stretches with content */
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }


    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

    .form-header h2 {
        margin: 0;
        font-size: 1.75rem;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .form-header p {
        margin: 0.5rem 0 0 0;
        opacity: 0.9;
        font-size: 0.95rem;
    }

    .form-body {
        padding: 2.5rem;
    }

    .form-group-modern {
        margin-bottom: 1.75rem;
    }

    .form-label-modern {
        display: block;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-label-modern .required {
        color: #dc3545;
        margin-left: 0.25rem;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: #007BFF;
        background-color: #fff;
        box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
    }

    textarea.form-control-modern {
        resize: vertical;
        min-height: 120px;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #718096;
        font-size: 1rem;
    }

    .input-icon-wrapper .form-control-modern {
        padding-left: 2.75rem;
    }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .btn-modern-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        cursor: pointer;
    }

    .btn-modern-primary:hover {
        background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
    }

    .btn-modern-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #495057;
        font-weight: 500;
        font-size: 0.95rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-modern-secondary:hover {
        background: #f8f9fa;
        border-color: #adb5bd;
        color: #212529;
        transform: translateY(-1px);
    }

    .field-description {
        background: #fff3cd;
        border-left: 3px solid #ffc107;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        color: #856404;
    }

    /* ✅ Success Popup */
    .success-popup {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: all 0.3s ease;
    }

    .success-popup.hidden {
        opacity: 0;
        visibility: hidden;
    }

    .success-popup-content {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 3rem;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        animation: popupFadeIn 0.4s ease forwards;
        max-width: 420px;
        border-top: 6px solid #28a745;
        transform: scale(0.7);
    }

    .success-popup.hidden .success-popup-content {
        transform: scale(0.7);
    }

    .success-popup:not(.hidden) .success-popup-content {
        transform: scale(1);
    }

    @@keyframes popupFadeIn {
        from {
            transform: scale(0.7) translateY(-50px);
            opacity: 0;
        }
        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    .success-popup-content i {
        font-size: 3rem;
        color: #28a745;
        margin-bottom: 1rem;
    }

    .success-popup-content h4 {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
    }

    .success-popup-content p {
        font-size: 0.95rem;
        color: #718096;
        margin-bottom: 1.5rem;
    }

    .success-popup-content button {
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .success-popup-content button:hover {
        background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
        transform: translateY(-2px);
      
    }
</style>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2><i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]</h2>
            <p>Update the information below to modify the field of specialization</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="FieldOfSpecId" />
            
            <div class="form-body">
                <div class="field-description">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    You are editing an existing record. Fields marked with <span style="color: #dc3545; font-weight: 600;">*</span> are required
                </div>

                <!-- Field Name -->
                <div class="form-group-modern">
                    <label class="form-label-modern">
                        <i class="bi bi-tag me-1"></i> Field Name <span class="required">*</span>
                    </label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-bookmark-fill"></i>
                        <input asp-for="FieldOfSpecName" class="form-control-modern" 
                               placeholder="Enter field of specialization name" required />
                    </div>
                    <span asp-validation-for="FieldOfSpecName" class="text-danger small"></span>
                </div>

                <!-- Description -->
                <div class="form-group-modern">
                    <label class="form-label-modern">
                        <i class="bi bi-journal-text me-1"></i> Description
                    </label>
                    <textarea asp-for="Desc" class="form-control-modern" 
                              placeholder="Enter a detailed description (optional)" rows="5"></textarea>
                    <span asp-validation-for="Desc" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-save"></i> Update Field
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ✅ Success Popup -->
<div id="successPopup" class="success-popup hidden">
    <div class="success-popup-content">
        <i class="bi bi-check-circle-fill"></i>
        <h4>Updated Successfully!</h4>
        <p>The field of specialization has been updated in the system.</p>
        <button id="popupCloseBtn">
            OK
        </button>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Form Validation
        document.querySelector('form').addEventListener('submit', function (e) {
            const requiredFields = this.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    isValid = false;
                    field.style.borderColor = '#dc3545';
                } else {
                    field.style.borderColor = '#e2e8f0';
                }
            });

            if (!isValid) {
                e.preventDefault();
                alert('Please fill in all required fields marked with *');
            }
        });

        // Reset border color on input
        document.querySelectorAll('.form-control-modern').forEach(field => {
            field.addEventListener('input', function() {
                this.style.borderColor = '#e2e8f0';
            });
        });

        // Show popup if TempData message exists
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            window.addEventListener('DOMContentLoaded', () => {
                document.getElementById('successPopup').classList.remove('hidden');
            });
            </text>
        }

        // Close popup
        document.getElementById('popupCloseBtn').addEventListener('click', function () {
            document.getElementById('successPopup').classList.add('hidden');
            window.location.href = '@Url.Action("Index")';
        });

        // Close popup on outside click
        document.getElementById('successPopup').addEventListener('click', function(e) {
            if (e.target === this) {
                this.classList.add('hidden');
                window.location.href = '@Url.Action("Index")';
            }
        });
    </script>
}