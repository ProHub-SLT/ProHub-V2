@model ProHub.Models.ParentProject
@{
    ViewData["Title"] = "Edit Application Group";
}

<style>
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
        position: relative;
    }

        /* Blur overlay */
        body::before {
            content: "";
            position: absolute; /* changed from fixed */
            top: 0;
            left: 0;
            width: 100%;
            min-height: 100%; /* ensures it stretches with content */
            background: inherit;
            filter: blur(1px);
            z-index: -1;
        }

    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(90deg, #007BFF 0%, #28A745 100%);
        padding: 2rem;
        color: white;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .form-header p {
            margin: 0.5rem 0 0 0;
            opacity: 0.9;
            font-size: 0.95rem;
        }

    .form-body {
        padding: 2.5rem;
    }

    .form-group-modern {
        margin-bottom: 1.75rem;
    }

    .form-label-modern {
        display: block;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

        .form-label-modern .required {
            color: #dc3545;
            margin-left: 0.25rem;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #28A745;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #718096;
            font-size: 1rem;
        }

        .input-icon-wrapper .form-control-modern {
            padding-left: 2.75rem;
        }

    .form-footer {
        background-color: #f8f9fa;
        padding: 1.5rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e2e8f0;
    }

    .btn-modern-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        cursor: pointer;
    }

        .btn-modern-primary:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
        }

    .btn-modern-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #495057;
        font-weight: 500;
        font-size: 0.95rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-modern-secondary:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            color: #212529;
            transform: translateY(-1px);
        }

    .field-description {
        background: #f0f9ff;
        border-left: 3px solid #007BFF;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        color: #2d3748;
    }

    .success-popup {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: all 0.3s ease;
    }

        .success-popup.hidden {
            opacity: 0;
            visibility: hidden;
        }

    .success-popup-content {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 3rem;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        animation: popupFadeIn 0.4s ease forwards;
        max-width: 420px;
        border-top: 6px solid #28a745;
    }

        .success-popup-content i {
            font-size: 3rem;
            color: #28a745;
            margin-bottom: 1rem;
        }

        .success-popup-content h4 {
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 0.5rem;
        }

        .success-popup-content p {
            font-size: 0.95rem;
            color: #718096;
            margin-bottom: 1.5rem;
        }

        .success-popup-content button {
            padding: 0.6rem 1.5rem;
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .success-popup-content button:hover {
                background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            }

    @@keyframes popupFadeIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<div class="container-fluid mt-4">
    <div class="form-container">
        <div class="form-header">
            <h2><i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]</h2>
            <p>Update the details below to edit the application group</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="ParentProjectID" />
            <div class="form-body">
                <div class="field-description">
                    <i class="bi bi-info-circle me-2"></i>
                    Update the fields below to modify the application group details
                </div>

                <!-- Parent Project Group -->
                <div class="form-group-modern">
                    <label asp-for="ParentProjectGroup" class="form-label-modern"><i class="bi bi-folder me-1"></i> Parent Project Group <span class="required">*</span></label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-folder-fill"></i>
                        <input asp-for="ParentProjectGroup" class="form-control-modern" placeholder="Enter project group name" required />
                    </div>
                </div>

                <!-- Operation Scope -->
                <div class="form-group-modern">
                    <label asp-for="OperationScope" class="form-label-modern"> <i class="bi bi-diagram-3 me-1"></i> </i> Operation Scope</label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-gear-fill"></i>
                        <input asp-for="OperationScope" class="form-control-modern" placeholder="Enter operation scope" r />
                    </div>
                </div>
            </div>

            <div class="form-footer">
                <a asp-action="Index" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Success Popup -->
<div id="successPopup" class="success-popup hidden">
    <div class="success-popup-content">
        <i class="bi bi-check-circle-fill"></i>
        <h4>Application Group Updated Successfully!</h4>
        <p>The application group details have been saved to the system.</p>
        <button id="popupCloseBtn">OK</button>
    </div>
</div>

@section Scripts {
    <script>
        // Validation
        document.querySelector('form').addEventListener('submit', function (e) {
            const requiredFields = this.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value) {
                    isValid = false;
                    field.style.borderColor = '#dc3545';
                } else {
                    field.style.borderColor = '#e2e8f0';
                }
            });

            if (!isValid) {
                e.preventDefault();
                alert('Please fill in all required fields marked with *');
            }
        });

        // Show popup if TempData message exists
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                window.addEventListener('DOMContentLoaded', () => {
                    document.getElementById('successPopup').classList.remove('hidden');
                });
            </text>
        }

            // Close popup
            document.getElementById('popupCloseBtn').addEventListener('click', function () {
                document.getElementById('successPopup').classList.add('hidden');
                window.location.href = '@Url.Action("Index")';
            });
    </script>
}