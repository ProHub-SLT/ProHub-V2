        }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #6c757d;
    }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #dee2e6;
        }

    /* Modals CSS */
    .delete-modal-overlay, .success-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

        .delete-modal-overlay.show, .success-modal-overlay.show {
            opacity: 1;
            visibility: visible;
        }

    .delete-modal-content, .success-modal-content {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 3rem;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        max-width: 450px;
        width: 90%;
        transform: scale(0.7);
        animation: modalSlideIn 0.4s ease forwards;
    }

    .delete-modal-content {
        border-top: 6px solid #dc3545;
    }

    .success-modal-content {
        border-top: 6px solid #28a745;
    }

    .delete-modal-overlay.show .delete-modal-content, .success-modal-overlay.show .success-modal-content {
        transform: scale(1);
    }

    @@keyframes modalSlideIn {
        from {
            transform: scale(0.7) translateY(-50px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    .delete-modal-content i.warning-icon {
        font-size: 3.5rem;
        color: #dc3545;
        margin-bottom: 1rem;
        animation: iconPulse 1.5s ease-in-out infinite;
    }

    .success-modal-content i {
        font-size: 3rem;
        color: #28a745;
        margin-bottom: 1rem;
    }

    @@keyframes iconPulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    .delete-modal-content h4, .success-modal-content h4 {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.75rem;
        font-size: 1.5rem;
    }

    .delete-modal-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .btn-modal-cancel {
        padding: 0.75rem 1.75rem;
        background: white;
        color: #495057;
        font-weight: 600;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-modal-cancel:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            transform: translateY(-1px);
        }

    .btn-modal-delete {
        padding: 0.75rem 1.75rem;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);
    }

        .btn-modal-delete:hover {
            background: linear-gradient(135deg, #c82333 0%, #bd2130 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(220, 53, 69, 0.35);
        }

    .btn-modal-ok {
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
    }

        .btn-modal-ok:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
        }

    /* Export Excel Style */
    .btn-export-excel {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.5rem;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.25);
        position: relative;
        overflow: hidden;
    }

        .btn-export-excel::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s ease;
        }

        .btn-export-excel:hover::before {
            left: 100%;
        }

        .btn-export-excel:hover {
            background: linear-gradient(135deg, #218838 0%, #1ba87d 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(40, 167, 69, 0.35);
            color: #fff;
        }
    /* --- Status Badges --- */
    .status-badge {
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .status-badge-prep {
        background-color: #f2f2f2;
        color: #616161;
        border-color: #d6d6d6;
    }

    .status-badge-submitted {
        background-color: #e1f5fe;
        color: #0277bd;
        border-color: #b3e5fc;
    }

    .status-badge-req {
        background-color: #e8eaf6;
        color: #283593;
        border-color: #c5cae9;
    }

    .status-badge-design {
        background-color: #f3e5f5;
        color: #7b1fa2;
        border-color: #e1bee7;
    }

    .status-badge-coding {
        background-color: #fff3e0;
        color: #ef6c00;
        border-color: #ffe0b2;
    }

    .status-badge-testing {
        background-color: #fff8e1;
        color: #ff8f00;
        border-color: #ffecb3;
    }

    .status-badge-deploy {
        background-color: #e8f5e9;
        color: #2e7d32;
