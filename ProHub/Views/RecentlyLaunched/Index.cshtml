@model IEnumerable<ProHub.Models.InternalPlatform>

@{
    ViewData["Title"] = "Internal Solutions - Recently Launched";

    // --- Pagination & Sort Logic (Null-Safe Parsing) ---
    // Using TryParse or explicit null checks handles cases where ViewBag values might be missing
    int pageSize = ViewBag.PageSize != null ? Convert.ToInt32(ViewBag.PageSize) : 10;
    int currentPage = ViewBag.CurrentPage != null ? Convert.ToInt32(ViewBag.CurrentPage) : 1;
    int totalRecords = ViewBag.TotalRecords != null ? Convert.ToInt32(ViewBag.TotalRecords) : 0;
    int totalPages = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;

    // Prevent division by zero or invalid page counts
    if (totalPages < 1) totalPages = 1;

    int startRecord = totalRecords > 0 ? (currentPage - 1) * pageSize + 1 : 0;
    int endRecord = totalRecords > 0 ? Math.Min(currentPage * pageSize, totalRecords) : 0;

    string sortColumn = (ViewBag.SortColumn as string) ?? "LaunchedDate";
    string sortOrder = (ViewBag.SortOrder as string) ?? "desc";
    // Normalize to lower case for comparison
    sortOrder = sortOrder.ToLowerInvariant();
    string searchTerm = (ViewBag.SearchTerm as string) ?? string.Empty;

    // --- Helpers ---

    // 1. Toggle Sort Order Helper
    string GetNextSortOrder(string column)
    {
        if (string.Equals(column, sortColumn, StringComparison.OrdinalIgnoreCase))
        {
            return sortOrder == "asc" ? "desc" : "asc";
        }
        return "asc";
    }

    // 2. URL Builder Helper (Keeps code clean in the HTML)
    string BuildUrl(int page, int size, string col, string order, string search)
    {
        return Url.Action("Index", new
        {
            page = page,
            pageSize = size,
            sortColumn = col,
            sortOrder = order,
            search = search
        }) ?? "#";
    }
}

<style>
    /* ... (Your existing styles) ... */
    body {
        margin: 0;
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
        background-color: #ffffff;
