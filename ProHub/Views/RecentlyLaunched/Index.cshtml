</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary mb-0">Internal Solutions - Recently Launched</h1>
        <div class="text-muted small">
            <i class="bi bi-calendar-check me-1"></i> Showing projects launched in the current year
        </div>
    </div>

    @* --- Toolbar --- *@
    <div class="toolbar-wrapper mb-4">
        <div class="row g-3 align-items-center">

            @* --- 1. Create Button --- *@
            <div class="col-lg-3 col-md-4 col-sm-6">
                <a asp-controller="InternalSolution" asp-action="Create" class="btn-action-base btn-create-new">
                    <i class="bi bi-plus-circle"></i>
                    <span>Create New</span>
                </a>
            </div>

            @* --- 2. Search Box --- *@
            <div class="col-lg-5 col-md-6">
                <form method="get" asp-action="Index" class="d-flex align-items-center bg-white rounded-3 px-3 py-1 border">
                    <i class="bi bi-search text-muted me-2"></i>
                    <input type="text" name="search" class="form-control border-0 shadow-none"
                           placeholder="Search launched solutions..." value="@searchTerm" />

                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        @* Reset Search Link *@
                        <a href="@BuildUrl(1, pageSize, sortColumn, sortOrder, "")" class="text-secondary text-decoration-none me-2">
                            <i class="bi bi-x-circle-fill"></i>
                        </a>
                    }

                    @* Maintain current page size when searching *@
                    <input type="hidden" name="pageSize" value="@pageSize" />

                    <button type="submit" class="btn btn-search btn-sm ms-2 px-3">
                        Search
                    </button>
                </form>
            </div>

            @* --- 3. Page Size Selector --- *@
            <div class="col-lg-4 col-md-12 d-flex justify-content-lg-end justify-content-start">
                <form method="get" asp-action="Index" id="entriesForm"
                      class="d-flex align-items-center bg-white rounded-3 px-3 py-2 border">
                    <label class="me-2 text-nowrap text-secondary small fw-semibold">Show</label>


                    <select name="pageSize" class="form-select form-select-sm border-0 shadow-none fw-semibold"
                            onchange="this.form.submit()">
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="25" selected="@(pageSize == 25)">25</option>
                        <option value="50" selected="@(pageSize == 50)">50</option>
                        <option value="100" selected="@(pageSize == 100)">100</option>
                    </select>

                    <span class="ms-2 small text-secondary">entries</span>
                    @* Maintain current search and sort when changing page size *@
                    <input type="hidden" name="search" value="@searchTerm" />
                    <input type="hidden" name="sortColumn" value="@sortColumn" />
                    <input type="hidden" name="sortOrder" value="@sortOrder" />
                    <input type="hidden" name="page" value="1" />
                </form>
            </div>
        </div>
    </div>

    @* --- Data Table --- *@
    <div class="data-table-wrapper">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        @* Application Group (Sortable) *@
                        <th class="sortable" scope="col" style="width:12%">
                            <a href="@BuildUrl(1, pageSize, "ParentProjectGroupName", GetNextSortOrder("ParentProjectGroupName"), searchTerm)">
                                Application Group
                                <i class="bi @(sortColumn == "ParentProjectGroupName" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* App Name (Sortable) *@
                        <th class="sortable" scope="col" style="width:12%">
                            <a href="@BuildUrl(1, pageSize, "AppName", GetNextSortOrder("AppName"), searchTerm)">
                                Application Name
                                <i class="bi @(sortColumn == "AppName" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* Developed By (Sortable) *@
                        <th class="sortable" scope="col" style="width:10%">
                            <a href="@BuildUrl(1, pageSize, "DevelopedBy", GetNextSortOrder("DevelopedBy"), searchTerm)">
                                Developed By
                                <i class="bi @(sortColumn == "DevelopedBy" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* SDLC Phase (Sortable) *@
                        <th class="sortable" scope="col" style="width:13%">
                            <a href="@BuildUrl(1, pageSize, "SDLCPhase", GetNextSortOrder("SDLCPhase"), searchTerm)">
                                SDLC Phase
                                <i class="bi @(sortColumn == "SDLCPhase" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* Start (Sortable) *@
                        <th class="sortable" style="width:10%">
                            <a href="@BuildUrl(1, pageSize, "Start", GetNextSortOrder("Start"), searchTerm)">
                                Start <i class="bi @(sortColumn == "Start" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* Target (Sortable) *@
                        <th class="sortable" style="width:10%">
                            <a href="@BuildUrl(1, pageSize, "Target", GetNextSortOrder("Target"), searchTerm)">
                                Target <i class="bi @(sortColumn == "Target" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* User Dept? (UD) (Sortable) *@
                        <th class="sortable" style="width:10%">
                            <a href="@BuildUrl(1, pageSize, "UD", GetNextSortOrder("UD"), searchTerm)">
                                UD <i class="bi @(sortColumn == "UD" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        @* Price/Value (Sortable) *@
                        <th class="sortable" scope="col" style="width:10%">
                            <a href="@BuildUrl(1, pageSize, "Price", GetNextSortOrder("Price"), searchTerm)">
                                Value
                                <i class="bi @(sortColumn == "Price" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th scope="col" style="width:13%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td title="@item.ParentProjectGroupName">@item.ParentProjectGroupName</td>
                                <td>
                                    <div class="fw-semibold text-truncate" title="@item.AppName">@item.AppName</div>
                                    @if (!string.IsNullOrEmpty(item.MainAppName))
                                    {
                                        <div class="small text-primary fst-italic mt-1">
                                            <i class="bi bi-arrow-return-right"></i> CR of @item.MainAppName
                                        </div>
                                    }
                                </td>
                                <td title="@(item.DevelopedByName ?? "-")">@(item.DevelopedByName ?? "-")</td>

                                <td>
                                    @{
                                        // Logic to apply color badges based on Phase name
                                        var phaseName = item.SDLCPhaseName ?? "Maintenance";
                                        var p = phaseName.ToLower().Trim();
                                        var badgeClass = "status-badge status-badge-default";

                                        if (p.Contains("proposal preparation")) { badgeClass = "status-badge status-badge-prep"; }
                                        else if (p.Contains("proposal submitted")) { badgeClass = "status-badge status-badge-submitted"; }
                                        else if (p.Contains("requirement") || p.Contains("gathering")) { badgeClass = "status-badge status-badge-req"; }
                                        else if (p.Contains("design")) { badgeClass = "status-badge status-badge-design"; }
                                        else if (p.Contains("coding") || p.Contains("implementation") || p.Contains("development")) { badgeClass = "status-badge status-badge-coding"; }
                                        else if (p.Contains("testing") || p.Contains("qa")) { badgeClass = "status-badge status-badge-testing"; }
                                        else if (p.Contains("deployment") || p.Contains("completed") || p.Contains("live")) { badgeClass = "status-badge status-badge-deploy"; }
                                        else if (p.Contains("maintenance")) { badgeClass = "status-badge status-badge-maintenance"; }
                                    }
                                    <span class="@badgeClass">
                                        @phaseName
                                    </span>
                                </td>

                                <td title="@(item.StartDate?.ToString("MMM dd, yyyy") ?? "-")">@(item.StartDate?.ToString("MMM dd, yyyy") ?? "-")</td>

                                <td title="@(item.TargetDate?.ToString("MMM dd, yyyy") ?? "-")">@(item.TargetDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td>@(item.AppUsers ?? "-")</td>

                                <td title="Rs.@(item.Price)">Rs.@(item.Price)</td>

                                <td class="text-center">
                                    <a asp-controller="InternalSolution" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a asp-controller="InternalSolution" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Details"><i class="bi bi-eye"></i></a>
                                    <button type="button" class="btn btn-sm btn-outline-danger me-1"
                                            onclick="showDeleteModal(@item.Id, '@item.AppName')" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                    <a asp-controller="InternalSolution" asp-action="Folder" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1" title="Filter Documents">
                                        <i class="bi bi-folder"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="empty-state">
                                <i class="bi bi-rocket fs-1 mb-2"></i>
                                <p class="mb-0">No recently launched solutions found.</p>
                                <small class="text-muted">Solutions launched in the last 6 months will appear here.</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- Excel Button --- *@
    <div class="mt-3 d-flex justify-content-start gap-2">
        <a asp-action="ExportToExcel"
           asp-route-search="@searchTerm"
           class="btn-action-base btn-export-excel">
            <i class="bi bi-file-earmark-excel"></i>
            <span>Export Recently Launched to Excel</span>
        </a>
    </div>

    @* --- Pagination Footer --- *@
    <div class="row mt-3 align-items-center">
        <div class="col-md-6">
            <p class="text-muted mb-0">Showing @startRecord to @endRecord of @totalRecords entries</p>
        </div>
        <div class="col-md-6">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@BuildUrl(Math.Max(1, currentPage - 1), pageSize, sortColumn, sortOrder, searchTerm)">Previous</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@BuildUrl(i, pageSize, sortColumn, sortOrder, searchTerm)">@i</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@BuildUrl(Math.Min(totalPages, currentPage + 1), pageSize, sortColumn, sortOrder, searchTerm)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@* --- Delete Modal --- *@
<div id="deleteModal" class="delete-modal-overlay">
    <div class="delete-modal-content">
        <i class="bi bi-exclamation-triangle-fill warning-icon"></i>
        <h4>Are You Sure?</h4>
        <p>You are about to delete:</p>
        <p class="item-name" id="deleteItemName"></p>
        <p style="color: #dc3545; font-size: 0.9rem;">This action cannot be undone!</p>
        <div class="delete-modal-actions">
            <button type="button" class="btn-modal-cancel" onclick="closeDeleteModal()">
                <i class="bi bi-x-circle me-1"></i> Cancel
            </button>

            <form id="deleteForm" method="post" asp-controller="InternalSolution" asp-action="Delete" style="display: inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteId" />
                <button type="submit" class="btn-modal-delete">
                    <i class="bi bi-trash-fill me-1"></i> Yes, Delete
                </button>
            </form>
        </div>
    </div>
</div>

@* --- Success Modal --- *@
<div id="successModal" class="success-modal-overlay">
    <div class="success-modal-content">
        <i class="bi bi-check-circle-fill"></i>
        <h4>Success!</h4>
        <p>@TempData["SuccessMessage"]</p>
        <button type="button" class="btn-modal-ok" onclick="closeSuccessModal()">
            OK
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // --- Modal Functions ---
        function showDeleteModal(id, name) {
            document.getElementById('deleteItemName').textContent = name;
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteModal').classList.add('show');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('show');
        }

        function closeSuccessModal() {
            document.getElementById('successModal').classList.remove('show');
        }

        // Close on outside click
        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) closeDeleteModal();
        });
        document.getElementById('successModal').addEventListener('click', function (e) {
            if (e.target === this) closeSuccessModal();
        });

        // Show success modal if TempData message exists
        @if (TempData["SuccessMessage"] != null)
        {
                    <text>
                        window.addEventListener('DOMContentLoaded', () => {
                            document.getElementById('successModal').classList.add('show');
                        });
                    </text>
        }
    </script>
}