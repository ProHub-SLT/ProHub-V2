    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- ✅ COMPLETELY FIXED: Mobile Dropdown JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            console.log('✅ PROHUB Layout: Fixed mobile dropdowns initialized');

            const navbar = document.getElementById('navbarContent');
            const profileDropdown = document.querySelector('.profile-dropdown');

            // ✅ SIMPLIFIED: Mobile navbar auto-close (EXCLUDE profile)
            function setupMobileAutoClose() {
                const navigationLinks = document.querySelectorAll([
                    '.dropdown-item-prohub[href]:not([href="#"])',
                    '.nav-link-prohub[href]:not([href="#"])'
                ].join(','));

                navigationLinks.forEach(link => {
                    if (!link.closest('.profile-dropdown')) {
                        link.addEventListener('click', function (e) {
                            if (window.innerWidth < 992 &&
                                this.getAttribute('href') &&
                                this.getAttribute('href') !== '#') {

                                // Close navbar after short delay
                                setTimeout(() => {
                                    if (navbar && navbar.classList.contains('show')) {
                                        const bsCollapse = bootstrap.Collapse.getInstance(navbar);
                                        if (bsCollapse) {
                                            bsCollapse.hide();
                                        }
                                    }
                                }, 250);
                            }
                        });
                    }
                });
            }

            // ✅ FIXED: Click outside handler
            document.addEventListener('click', function (e) {
                if (window.innerWidth < 992) {
                    const navbarToggler = document.querySelector('.navbar-toggler');
                    const isClickInsideNavbar = navbar && navbar.contains(e.target);
                    const isToggleClick = navbarToggler && navbarToggler.contains(e.target);

                    if (!isClickInsideNavbar && !isToggleClick &&
                        navbar && navbar.classList.contains('show')) {

                        // Check if profile dropdown is open
                        const profileMenu = document.querySelector('.profile-dropdown .dropdown-menu.show');
                        if (!profileMenu) {
                            const bsCollapse = bootstrap.Collapse.getInstance(navbar);
                            if (bsCollapse) {
                                bsCollapse.hide();
                            }
                        }
                    }
                }
            });

            // ✅ FIXED: Reset dropdowns when navbar collapses
            if (navbar) {
                navbar.addEventListener('hidden.bs.collapse', function () {
                    // Close only regular dropdowns
                    document.querySelectorAll('.dropdown-menu:not(.profile-dropdown .dropdown-menu)').forEach(menu => {
                        if (menu.classList.contains('show')) {
                            menu.classList.remove('show');
                        }
                    });

                    document.querySelectorAll('.dropdown-toggle:not(.profile-dropdown .dropdown-toggle)').forEach(toggle => {
                        if (toggle.getAttribute('aria-expanded') === 'true') {
                            toggle.setAttribute('aria-expanded', 'false');
                        }
                    });
                });
            }

            // ✅ Handle window resize
            let resizeTimeout;
            window.addEventListener('resize', function () {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(function () {
                    if (window.innerWidth >= 992) {
                        document.querySelectorAll('.dropdown-menu').forEach(menu => {
                            menu.classList.remove('show');
                        });
                        document.querySelectorAll('.dropdown-toggle').forEach(toggle => {
                            toggle.setAttribute('aria-expanded', 'false');
                        });
                    }
                }, 250);
            });

            // ✅ Initialize mobile auto-close
            setupMobileAutoClose();

            // ✅ FORCE Profile dropdown initialization
            const profileToggle = document.querySelector('#profileDropdown');
            if (profileToggle) {
                // Destroy existing instance if any
                const existingInstance = bootstrap.Dropdown.getInstance(profileToggle);
                if (existingInstance) {
                    existingInstance.dispose();
                }

                // Create new Bootstrap dropdown instance
                new bootstrap.Dropdown(profileToggle, {
                    autoClose: true
                });

                console.log('✅ Profile dropdown initialized successfully');
            }

            // ✅ Profile dropdown touch enhancement for mobile
            if (profileToggle) {
                profileToggle.addEventListener('click', function (e) {
                    console.log('Profile dropdown clicked');
                    // Let Bootstrap handle everything naturally
                });
            }

            console.log('✅ All mobile dropdown fixes applied successfully');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>