                <!-- Profile / Login Section -->
                <ul class="navbar-nav ms-auto">
                    @{
                        string displayName = User.FindFirst("name")?.Value ?? "Guest";
                        string email = User.FindFirst("preferred_username")?.Value
                        ?? User.FindFirst("upn")?.Value
                        ?? "Not logged in";
                        string initials = "U";
                        if (!string.IsNullOrEmpty(displayName) && displayName != "Guest")
                        {
                            var parts = displayName.Split(' ');
                            if (parts.Length == 1)
                                initials = parts[0][0].ToString().ToUpper();
                            else
                                initials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
                        }
                        var rolesList = User.Claims
                        .Where(c => c.Type.EndsWith("/role") || c.Type == "roles")
                        .Select(c => c.Value)
                        .ToList();
                    }
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown profile-dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               data-bs-auto-close="true"
                               aria-expanded="false"
