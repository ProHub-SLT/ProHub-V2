@model IEnumerable<ProHub.Models.Trainees>

@{
    ViewData["Title"] = "Active Trainees";

    // --- Pagination & Sort Logic ---
    int pageSize = Convert.ToInt32(ViewData["PageSize"] ?? 10);
    int currentPage = Convert.ToInt32(ViewData["CurrentPage"] ?? 1);
    int totalRecords = Convert.ToInt32(ViewData["TotalEntries"] ?? 0);
    int totalPages = Convert.ToInt32(ViewData["TotalPages"] ?? 1);
    if (totalPages == 0) totalPages = 1;

    int startRecord = totalRecords > 0 ? (currentPage - 1) * pageSize + 1 : 0;
    int endRecord = totalRecords > 0 ? Math.Min(currentPage * pageSize, totalRecords) : 0;

    string sortColumn = (ViewData["SortColumn"] ?? "Trainee_ID").ToString();
    string sortOrder = (ViewData["SortOrder"] ?? "desc").ToString().ToLowerInvariant();
    string searchTerm = (ViewData["SearchTerm"] ?? string.Empty).ToString();

    // Helper for sorting toggles
    Func<string, string> ToggleSortOrder = column =>
    {
        if (string.Equals(column, sortColumn, StringComparison.OrdinalIgnoreCase))
        {
            return sortOrder == "asc" ? "desc" : "asc";
        }
        return "asc";
    };

    // Helper to build URLs preserving state
    // FIX: Changed Action from "Index" to "ActiveTrainee" to match your Controller
    Func<int, int, string, string, string, string> BuildIndexUrl = (page, pageSizeLocal, sortCol, sortOrd, search) =>
    {
        return Url.Action("ActiveTrainee", new
        {
            page,
            pageSize = pageSizeLocal,
            sortColumn = sortCol,
            sortOrder = sortOrd,
            search
        }) ?? "#";
    };
}

<style>
