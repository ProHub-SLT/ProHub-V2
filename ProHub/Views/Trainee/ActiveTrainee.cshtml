<div class="container-fluid mt-4">
    <h1 class="mb-4 text-primary">Active Trainees</h1>

    <div class="toolbar-wrapper mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <a asp-controller="Trainee" asp-action="Create" class="btn-create-new">
                    <i class="bi bi-plus-circle"></i>
                    <span>Create New </span>
                </a>
            </div>

            <div class="col-lg-5 col-md-6">
                <form method="get" asp-controller="Trainee" asp-action="ActiveTrainee" class="d-flex align-items-center bg-white rounded-3 px-3 py-1 border">
                    <i class="bi bi-search text-muted me-2"></i>
                    <input type="text" name="search" class="form-control border-0 shadow-none"
                           placeholder="Search by ID, Name, NIC, or Institute..." value="@searchTerm" />
                    <input type="hidden" name="pageSize" value="@pageSize" />
                    <button type="submit" class="btn btn-search btn-sm ms-2 px-3">
                        Search
                    </button>
                </form>
            </div>

            <div class="col-lg-4 col-md-12 d-flex justify-content-lg-end justify-content-start">
                <form method="get" asp-controller="Trainee" asp-action="ActiveTrainee" id="entriesForm"
                      class="d-flex align-items-center bg-white rounded-3 px-3 py-2 border">
                    <label class="me-2 text-nowrap text-secondary small fw-semibold">Show</label>
                    <select name="pageSize" class="form-select form-select-sm border-0 shadow-none fw-semibold"
                            onchange="this.form.submit()">
                        <!option value="10" @(pageSize == 10 ? "selected" : "")>10</!option>
                        <!option value="25" @(pageSize == 25 ? "selected" : "")>25</!option>
                        <!option value="50" @(pageSize == 50 ? "selected" : "")>50</!option>
                        <!option value="100" @(pageSize == 100 ? "selected" : "")>100</!option>
                    </select>
                    <span class="ms-2 small text-secondary">entries</span>
                    <input type="hidden" name="search" value="@searchTerm" />
                    <input type="hidden" name="page" value="1" />
                </form>
            </div>
        </div>
    </div>

    <div class="data-table-wrapper">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="sortable" scope="col" style="width: 80px;">
                            <a href="@BuildIndexUrl(1, pageSize, "Trainee_ID", ToggleSortOrder("Trainee_ID"), searchTerm)">
                                Trainee ID <i class="bi @(sortColumn == "Trainee_ID" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Trainee_Name", ToggleSortOrder("Trainee_Name"), searchTerm)">
                                Name <i class="bi @(sortColumn == "Trainee_Name" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th scope="col">Contact Info</th>
                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Trainee_NIC", ToggleSortOrder("Trainee_NIC"), searchTerm)">
                                NIC <i class="bi @(sortColumn == "Trainee_NIC" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Training_StartDate", ToggleSortOrder("Training_StartDate"), searchTerm)">
                                Training<br> Start Date <i class="bi @(sortColumn == "Training_StartDate" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Training_EndDate", ToggleSortOrder("Training_EndDate"), searchTerm)">
                                Training <br>End Date <i class="bi @(sortColumn == "Training_EndDate" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Institute", ToggleSortOrder("Institute"), searchTerm)">
                                Institute <i class="bi @(sortColumn == "Institute" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>
                        <th class="sortable" scope="col">
                            <a href="@BuildIndexUrl(1, pageSize, "Supervisor", ToggleSortOrder("Supervisor"), searchTerm)">
                                Supervisor <i class="bi @(sortColumn == "Supervisor" ? (sortOrder == "asc" ? "bi-arrow-up" : "bi-arrow-down") : "bi-arrow-down-up") ms-1 sort-icon"></i>
                            </a>
                        </th>

                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fw-semibold ">@item.FormattedTrainee_ID</span></td>
                                <td>
                                    <div class="fw-medium">@item.Trainee_Name</div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column small text-muted">
                                        <span><i class="bi bi-telephone me-1"></i> @(item.Trainee_Phone ?? "-")</span>
                                        @if (!string.IsNullOrEmpty(item.Trainee_Email))
                                        {
                                            <span><i class="bi bi-envelope me-1"></i> @item.Trainee_Email</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Trainee_HomeAddress))
                                        {
                                            <span class="text-truncate" style="max-width: 200px;" title="@item.Trainee_HomeAddress"><i class="bi bi-geo-alt me-1"></i> @item.Trainee_HomeAddress</span>
                                        }
                                    </div>
                                </td>
                                <td>@item.Trainee_NIC</td>
                                <td>@(item.Training_StartDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td>@(item.Training_EndDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td>@(item.Institute ?? "-")</td>
                                <td>@(item.SupervisorName ?? "N/A")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Edit" asp-route-id="@item.Trainee_ID" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Trainee_ID" class="btn btn-sm btn-outline-info me-1" title="Details"><i class="bi bi-eye"></i></a>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="showDeleteModal(@item.Trainee_ID, '@item.Trainee_Name')" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="empty-state">
                                <i class="bi bi-people fs-1 mb-2"></i>
                                <p class="mb-0">No active trainees found</p>
                                <small class="text-muted">Get started by adding a new trainee.</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row mt-3 align-items-center">
        <div class="col-md-6">
            <p class="text-muted mb-0">Showing @startRecord to @endRecord of @totalRecords entries</p>
        </div>
        <div class="col-md-6">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@BuildIndexUrl(Math.Max(1, currentPage - 1), pageSize, sortColumn, sortOrder, searchTerm)">Previous</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@BuildIndexUrl(i, pageSize, sortColumn, sortOrder, searchTerm)">@i</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@BuildIndexUrl(Math.Min(totalPages, currentPage + 1), pageSize, sortColumn, sortOrder, searchTerm)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<div id="deleteModal" class="delete-modal-overlay">
    <div class="delete-modal-content">
        <i class="bi bi-exclamation-triangle-fill warning-icon"></i>
        <h4>Are You Sure?</h4>
        <p>You are about to delete trainee:</p>
        <p class="item-name" id="deleteItemName"></p>
        <p style="color: #dc3545; font-size: 0.9rem;">This action cannot be undone!</p>
        <div class="delete-modal-actions">
            <button type="button" class="btn-modal-cancel" onclick="closeDeleteModal()">
                <i class="bi bi-x-circle me-1"></i> Cancel
            </button>
            <form id="deleteForm" method="post" asp-action="Delete" style="display: inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteId" />

                <input type="hidden" name="page" value="@currentPage" />
                <input type="hidden" name="pageSize" value="@pageSize" />
                <input type="hidden" name="search" value="@searchTerm" />

                <button type="submit" class="btn-modal-delete">
                    <i class="bi bi-trash-fill me-1"></i> Yes, Delete
                </button>
            </form>
        </div>
    </div>
</div>

<div id="successModal" class="success-modal-overlay">
    <div class="success-modal-content">
        <i class="bi bi-check-circle-fill"></i>
        <h4>Success!</h4>
        <p>@TempData["SuccessMessage"]</p>
        <button type="button" class="btn-modal-ok" onclick="closeSuccessModal()">
            OK
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // --- Modal Functions ---
        function showDeleteModal(id, name) {
            document.getElementById('deleteItemName').textContent = name;
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteModal').classList.add('show');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('show');
        }

        function closeSuccessModal() {
            document.getElementById('successModal').classList.remove('show');
        }

        // --- Event Listeners ---

        // Close modals on outside click
        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });

        document.getElementById('successModal').addEventListener('click', function (e) {
            if (e.target === this) {
                closeSuccessModal();
            }
        });

        // Show success modal if TempData message exists
        @if (TempData["SuccessMessage"] != null)
        {
                    <text>
                        window.addEventListener('DOMContentLoaded', () => {
                            document.getElementById('successModal').classList.add('show');
                        });
                    </text>
        }
    </script>
}